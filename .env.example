# MK Fraud Readiness Score V1 - Consolidated Phase 0-7 environment template
# Do not place real secrets in this file.

# Public application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase public client values. Use anon key only for public client.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# Server-only Supabase values. Never expose these to the browser.
SUPABASE_SERVICE_ROLE_KEY=replace-only-in-vercel-or-local-secret-store
SUPABASE_JWT_SECRET=replace-only-if-required-by-server-verification

# Resume/snapshot-token security. Use a strong random pepper in real environments.
# TTLs match the Phase 2 v1.1 Blueprint token security design (section 7) and the
# respondent_token_policy row seeded into app_settings: resume tokens default 14 days while
# the assessment is a draft; snapshot and report-request tokens default 7 days.
# ASSESSMENT_SNAPSHOT_TOKEN_MAX_USES controls how many times a private free-snapshot link
# can be opened before validation fails. The Phase 7 server fallback is 100 when unset.
ASSESSMENT_TOKEN_PEPPER=replace-me
ASSESSMENT_RESUME_TOKEN_TTL_HOURS=336
ASSESSMENT_SNAPSHOT_TOKEN_TTL_HOURS=168
ASSESSMENT_REPORT_REQUEST_TOKEN_TTL_HOURS=168
ASSESSMENT_TOKEN_MAX_USES=25
ASSESSMENT_SNAPSHOT_TOKEN_MAX_USES=100

# Email
RESEND_API_KEY=replace-with-resend-api-key
MK_ADMIN_EMAIL=admin@mkfraud.co.za
MK_FROM_EMAIL=hello@mkfraud.co.za

# Storage bucket names from Phase 2 blueprint (section 10: payment-proofs, generated-reports)
SUPABASE_BUCKET_PAYMENT_PROOFS=payment-proofs
SUPABASE_BUCKET_REPORTS=generated-reports

# Rate limiting (Blueprint section 6/7: rate limit start, resume and token verification by IP,
# reference and email). Backed by supabase/migrations/0004_phase4_v1_2_rate_limiting.sql. Defaults below
# are used automatically if these are unset - only override if MK wants different thresholds.
RATE_LIMIT_ADMIN_LOGIN_PER_IP=20
RATE_LIMIT_ADMIN_LOGIN_PER_EMAIL=10
RATE_LIMIT_ASSESSMENT_START_PER_IP=10
RATE_LIMIT_ASSESSMENT_START_PER_EMAIL=5
RATE_LIMIT_ASSESSMENT_RESUME_PER_IP=30
RATE_LIMIT_ASSESSMENT_RESUME_PER_REFERENCE=20

# Deployment / release metadata
MK_RELEASE_CHANNEL=local
MK_BUILD_PHASE=phase-7-free-snapshot
